# Required — copy from: Supabase dashboard → Project Settings → Database → Connection string (Transaction pooler, port 6543)
# Supabase direct connections use IPv6; use the Supavisor transaction pooler (IPv4, no client limit).
# URL-encode any special characters in your password (e.g. $ → %24).
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Required — copy from: Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://[project-ref].supabase.co

# Required — copy from: Supabase dashboard → Project Settings → API → service_role key
# Keep this secret — never expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Required for production — add your Vercel URL (and localhost for local dev)
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# Optional overrides (all have sensible defaults — only set if you need to change them)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# MAX_ROWS_PER_QUERY=1000
# QUERY_TIMEOUT_SECONDS=30
# MAX_SAMPLE_ROWS=10
# MAX_CONCURRENT_TABLE_TASKS=10
# API_HOST=0.0.0.0
# API_PORT=8000
