# Production env for docker/docker-compose.prod.yml
# Copy to docker/.env.prod and fill in real values. Never commit docker/.env.prod.
#
# Supabase → Project Settings → Database → Connection string (session pooler, port 5432).
# URL-encode special chars in the password. NOTE: a literal `$` must be escaped as `$$`
# here because docker compose interpolates env files.
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:PASSWORD@aws-0-[region].pooler.supabase.com:5432/postgres
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres.[ref]:PASSWORD@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase → Project Settings → API
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM defaults (users can override per-account via the Settings UI)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# JSON array of allowed frontend origins (the deployed Vercel URL)
CORS_ORIGINS=["https://db-discovery-agent.vercel.app"]

# Query safety limits
MAX_ROWS_PER_QUERY=1000
QUERY_TIMEOUT_SECONDS=30
